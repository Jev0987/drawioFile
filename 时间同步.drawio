        <mxCell id="hyHQc6qYZTDK12X6ojay-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=17;" value="ptp4l&lt;div&gt;-i eth0&lt;/div&gt;&lt;div&gt;-f /etc/linuxptp/ptp4l-master.conf&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="290" x="940" y="1510" as="geometry" />
        </mxCell>
        <mxCell id="hyHQc6qYZTDK12X6ojay-3" edge="1" parent="1" style="endArrow=none;dashed=1;html=1;dashPattern=1 3;strokeWidth=2;rounded=0;" value="">
          <mxGeometry height="50" relative="1" width="50" as="geometry">
            <mxPoint x="730" y="660" as="sourcePoint" />
            <mxPoint x="730" y="-120" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="hyHQc6qYZTDK12X6ojay-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="&lt;div&gt;&lt;span&gt;[global]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 确保 AGX Orin 作为主时钟 (Master)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;gmCapable&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;1&amp;nbsp; &amp;nbsp;#&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;允许本机成为 Grandmaster&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;priority1&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;128&amp;nbsp; #&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;BMCA 选主优先级，128 是比较默认的值&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;priority2&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;128&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# PTP 域编号 (默认 0)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;domainNumber&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; 0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# === PTP E2E L2 关键配置 ===&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 1. 传输方式：Layer 2 (以太网帧)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;network_transport&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;L2&amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 2. 延时机制：End-to-End (端到端)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;delay_mechanism&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;E2E&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 3. 目标 MAC：标准 PTP L2 多播地址 (与 gPTP 的 MAC 地址不同!)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;ptp_dst_mac&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;01:1B:19:00:00:00&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 4. 传输特定字段：标准 PTP L2 为 0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;transportSpecific&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# === 报文发送频率 ===&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# Announce 报文频率: 2^0 = 1秒一次&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;logAnnounceInterval&amp;nbsp; &amp;nbsp; &amp;nbsp;0&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# Sync 报文频率: 2^-4 = 1/16 秒一次 (16Hz)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;logSyncInterval&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;-4&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# Delay Request 报文频率: 2^-4 = 1/16 秒一次&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;logMinDelayReqInterval&amp;nbsp; -4&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# === 硬件及调试 ===&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;assume_two_step&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;1&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;time_stamping&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;hardware&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;# 解决 AGX Orin 驱动超时问题&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;tx_timestamp_timeout&amp;nbsp; &amp;nbsp; 50&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="625" width="570" x="1750" y="447.5" as="geometry" />
        </mxCell>
